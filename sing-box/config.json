          "metacubex.one",
          "dl.google.com",
          "yacd.haishan.me"
        ]
      },
      {
        "server": "bypass",
        "geosite": [
          "category-games@cn"
        ]
      },
      {
        "server": "proxy",
        "geosite": "geolocation-!cn"
      },
      {
        "server": "bypass",
        "geosite": [
          "cn"
        ]
      },
      {
        "server": "direct",
        "geosite": [
          "private"
        ]
      }
    ]
  },
