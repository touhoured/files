      }
    ],
    "rules": [
      {
        "server": "direct",
        "process_name": [
          "libgeph.so",
          "geph4-client",
          "geph4-client_fallback",
          "geph4-client.exe",
          "geph4-client_fallback.exe"
        ]
      },
      {
        "server": "direct",
        "clash_mode": "direct"
      },
      {
        "server": "proxy",
        "clash_mode": "global"
      },
      {
        "server": "block",
        "geosite": "category-ads-all",
        "disable_cache": true
      },
      {
        "server": "bypass",
